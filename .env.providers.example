# ─────────────────────────────────────────────────────────────
# OllaBridge Cloud — Free LLM Provider API Keys
# ─────────────────────────────────────────────────────────────
#
# Copy this file:   cp .env.providers.example .env.providers
# Then source it:   source .env.providers
#
# Or paste the exports directly into your .env file.
#
# All providers below offer FREE tiers. Click the link,
# sign up, copy your key, and paste it here.
# ─────────────────────────────────────────────────────────────


# ── Google Gemini (FREE) ────────────────────────────────────
# Best free overall — large context, strong reasoning.
# Free tier: 15 RPM, 1M TPM, 1500 RPD.
#
# 1. Go to:  https://aistudio.google.com/apikey
# 2. Click "Create API Key"
# 3. Copy and paste below
#
GEMINI_API_KEY=


# ── Groq (FREE) ────────────────────────────────────────────
# Fastest inference — ultra-low latency.
# Free tier: 30 RPM, 15K tokens/min for most models.
#
# 1. Go to:  https://console.groq.com/keys
# 2. Click "Create API Key"
# 3. Copy and paste below
#
GROQ_API_KEY=


# ── OpenRouter (FREE) ──────────────────────────────────────
# Aggregator with many free models (suffixed :free).
# Free tier: $0 cost on :free models, rate-limited.
#
# 1. Go to:  https://openrouter.ai/settings/keys
# 2. Click "Create Key"
# 3. Copy and paste below
#
OPENROUTER_API_KEY=


# ── Hugging Face (FREE) ────────────────────────────────────
# Open-source model inference — experimental.
# Free tier: rate-limited serverless inference.
#
# 1. Go to:  https://huggingface.co/settings/tokens
# 2. Click "Create new token" (type: Read)
# 3. Copy and paste below
#
HUGGINGFACE_API_KEY=


# ── DeepSeek (CHEAP, not free) ─────────────────────────────
# Strong reasoning model — very low cost.
# Pricing: ~$0.14/M input tokens, $0.28/M output tokens.
#
# 1. Go to:  https://platform.deepseek.com/api_keys
# 2. Click "Create new API key"
# 3. Copy and paste below
#
DEEPSEEK_API_KEY=


# ─────────────────────────────────────────────────────────────
# Quick test after setting keys:
#
#   source .env.providers
#   python scripts/test_providers.py
#
# Expected output:
#
#   Provider         Status    Latency   Tier         Notes
#   ----------------------------------------------------------
#   gemini-free      OK        820ms     main         Best free overall
#   groq-free        OK        290ms     main         Fastest
#   openrouter-free  OK        1100ms    main         Flexible
#   huggingface-free OK        2100ms    secondary    Experimental
#   deepseek-cheap   OK        980ms     secondary    Cheap fallback
# ─────────────────────────────────────────────────────────────
